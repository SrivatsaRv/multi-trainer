[flake8]
max-line-length = 88
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    # Exclude demo and seed data relative to container root
    app/db/demo_data.py,
    app/db/seed_test_data.py,
    verify_analytics.py,
    migrations
per-file-ignores =
    # Allow imports not at top in sitrep for path manipulation
    app/db/sitrep.py: E402
