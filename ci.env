# ============================================================
# CI/CD Registry Configuration
# ============================================================
# Swap these values to migrate between registries:
#   ttl.sh  -> No auth required, images expire after TTL_DURATION
#   ECR     -> Set REGISTRY=<account>.dkr.ecr.<region>.amazonaws.com
#   GHCR    -> Set REGISTRY=ghcr.io/<org>
#   DockerHub -> Set REGISTRY=docker.io/<org>
# ============================================================

REGISTRY=ttl.sh
BACKEND_IMAGE=multi-trainer-backend
FRONTEND_IMAGE=multi-trainer-frontend

# TTL.sh specific (ignored by other registries)
TTL_DURATION=24h
